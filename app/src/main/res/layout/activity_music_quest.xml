<?xml version="1.0" encoding="utf-8"?>
<io.mrarm.irc.view.OpaqueStatusBarRelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context="io.mrarm.irc.MusicQuestActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:theme="?attr/actionBarTheme">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="?attr/colorPrimary"
            app:popupTheme="@style/AppTheme.PopupOverlay" />

    </com.google.android.material.appbar.AppBarLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/appbar"
        android:orientation="vertical">

        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tabMenu"
            android:background="@color/colorPrimary"
            android:visibility="visible"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dialog_bottom_user_header_min_height" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <RelativeLayout
                android:id="@+id/rlRadio"
                android:visibility="visible"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <TextView
                    android:id="@+id/tvMimeType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MT"
                    android:layout_below="@+id/textView25"
                    android:layout_marginStart="25dp"
                    android:layout_alignParentStart="true" />

                <TextView
                    android:textColor="@color/colorAccent"
                    android:id="@+id/textView27"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="66dp"
                    android:text="RJ Name"
                    android:layout_alignParentTop="true"
                    android:layout_marginStart="25dp"
                    android:layout_alignParentStart="true" />

                <TextView
                    android:textColor="@color/colorAccent"
                    android:id="@+id/textView25"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MIME Type"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="25dp"
                    android:layout_alignParentStart="true" />

                <TextView
                    android:textColor="@color/colorAccent"
                    android:id="@+id/textView23"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SampleRate"
                    android:layout_below="@+id/tvBitRate"
                    android:layout_alignStart="@+id/textView27" />

                <TextView
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:id="@+id/textView26"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="29dp"
                    android:text="DETAILS"
                    android:layout_alignParentTop="true"
                    android:layout_marginStart="25dp"
                    android:layout_alignStart="@+id/textView27" />

                <TextView
                    android:id="@+id/tvBitRate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BR"
                    android:layout_below="@+id/textView16"
                    android:layout_alignStart="@+id/textView27" />

                <TextView
                    android:textColor="@color/colorAccent"
                    android:id="@+id/textView18"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="157dp"
                    android:text="Genre/Show"
                    android:layout_alignParentTop="true"
                    android:layout_marginStart="25dp"
                    android:layout_alignParentStart="true" />

                <TextView
                    android:textColor="@color/colorAccent"
                    android:id="@+id/textView24"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Channel"
                    android:layout_below="@+id/tvSampleRate"
                    android:layout_alignStart="@+id/textView27" />

                <TextView
                    android:id="@+id/tvChannel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CH"
                    android:layout_below="@+id/textView24"
                    android:layout_alignStart="@+id/textView27" />

                <TextView
                    android:textColor="@color/colorAccent"
                    android:id="@+id/textView22"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="111dp"
                    android:text="Now Playing"
                    android:layout_alignParentTop="true"
                    android:layout_marginStart="25dp"
                    android:layout_alignParentStart="true" />

                <TextView
                    android:id="@+id/tvGenre"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GN"
                    android:layout_below="@+id/textView18"
                    android:layout_marginStart="25dp"
                    android:layout_alignParentStart="true" />

                <TextView
                    android:id="@+id/rjName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RN"
                    android:layout_below="@+id/textView27"
                    android:layout_marginStart="25dp"
                    android:layout_alignParentStart="true" />

                <TextView
                    android:textColor="@color/colorAccent"
                    android:id="@+id/textView16"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bit Rate"
                    android:layout_below="@+id/tvMimeType"
                    android:layout_alignStart="@+id/textView27" />

                <TextView
                    android:id="@+id/tvSampleRate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SR"
                    android:layout_below="@+id/textView23"
                    android:layout_alignStart="@+id/textView27" />

                <TextView
                    android:ellipsize="marquee"
                    android:id="@+id/tvNowPlay"
                    android:fadingEdge="horizontal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NP"
                    android:singleLine="true"
                    android:layout_below="@+id/textView22"
                    android:marqueeRepeatLimit="marquee_forever"
                    android:layout_marginStart="25dp"
                    android:layout_alignParentStart="true" />
            </RelativeLayout>

            <ProgressBar
                android:id="@+id/progressBar3"
                android:visibility="invisible"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                style="?android:progressBarStyle" />

            <ListView
                android:id="@+id/listview"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="0dp" />

            <ImageView
                android:id="@+id/imageRadio"
                android:visibility="visible"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:baselineAligned="false"
                android:layout_alignParentTop="true"
                android:contentDescription="@string/action_radio"
                android:alpha="0.2"
                android:layout_alignParentStart="true"
                app:srcCompat="@drawable/ic_radio" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="50dp" />

            <androidx.viewpager.widget.ViewPager
                android:id="@+id/viewPager"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_alignParentTop="true"
                android:layout_alignParentStart="true" />

            <RelativeLayout
                android:orientation="horizontal"
                android:id="@+id/sub_player"
                android:background="@android:color/black"
                android:layout_width="match_parent"
                android:layout_height="85dp"
                android:layout_alignParentBottom="true"
                android:layout_alignParentStart="true">

                <ProgressBar
                    android:id="@+id/progressBar"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="7dp"
                    android:layout_alignParentBottom="true"
                    android:layout_marginEnd="135dp"
                    android:layout_alignParentEnd="true"
                    style="?android:progressBarStyle" />

                <TextView
                    android:textSize="18sp"
                    android:textColor="@android:color/white"
                    android:gravity="start|center"
                    android:id="@+id/name"
                    android:visibility="visible"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="10dp"
                    android:layout_marginTop="12dp"
                    android:text="@string/radio_off" />

                <TextView
                    android:textColor="@android:color/white"
                    android:ellipsize="marquee"
                    android:id="@+id/NowPlaying"
                    android:visibility="visible"
                    android:fadingEdge="horizontal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="10dp"
                    android:layout_marginTop="42dp"
                    android:scrollHorizontally="true"
                    android:singleLine="true"
                    android:layout_alignParentRight="true"
                    android:marqueeRepeatLimit="marquee_forever"
                    android:layout_marginStart="10dp"
                    android:layout_marginEnd="120dp" />

                <Button
                    android:textColor="@android:color/white"
                    android:id="@+id/playTrig"
                    android:background="@drawable/roundedbutton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/radio_play"
                    android:layout_alignParentTop="true"
                    android:drawableStart="@drawable/ic_play_white"
                    android:layout_marginEnd="21dp"
                    android:layout_alignParentEnd="true" />

                <TextView
                    android:textColor="@android:color/white"
                    android:ellipsize="marquee"
                    android:id="@+id/djName"
                    android:visibility="gone"
                    android:fadingEdge="horizontal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="13dp"
                    android:scrollHorizontally="true"
                    android:singleLine="true"
                    android:layout_alignParentTop="true"
                    android:marqueeRepeatLimit="marquee_forever"
                    android:layout_marginStart="111dp"
                    android:layout_alignParentStart="true" />
            </RelativeLayout>
        </RelativeLayout>
    </LinearLayout>
</io.mrarm.irc.view.OpaqueStatusBarRelativeLayout>
