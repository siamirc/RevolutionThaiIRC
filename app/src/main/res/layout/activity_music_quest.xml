<?xml version="1.0" encoding="utf-8"?>
<io.mrarm.irc.view.OpaqueStatusBarRelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context="io.mrarm.irc.MusicQuestActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:theme="?attr/actionBarTheme">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="?attr/colorPrimary"
            app:popupTheme="@style/AppTheme.PopupOverlay" />

    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/appbar"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Player Status Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="?attr/colorButtonNormal">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="center_horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Currently Playing"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorAccent"
                        android:textAllCaps="true"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/now_playing_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Loading song title..."
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="?android:attr/textColorPrimary"
                        android:gravity="center"
                        android:layout_marginBottom="16dp" />

                    <!-- Play/Pause Button -->
                    <Button
                        android:id="@+id/play_toggle_button"
                        android:layout_width="200dp"
                        android:layout_height="56dp"
                        android:text="TURN ON"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp"
                        android:gravity="center" />

                    <TextView
                        android:id="@+id/player_status_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Status: Stopped"
                        android:textSize="14sp"
                        android:textColor="?android:attr/textColorSecondary" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Stream Information Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="?attr/colorButtonNormal">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Stream Information"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorAccent"
                        android:textAllCaps="true"
                        android:layout_marginBottom="12dp" />

                    <!-- Stream Name -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingVertical="4dp">
                        <TextView
                            android:layout_width="140dp"
                            android:layout_height="wrap_content"
                            android:text="Stream Name:"
                            android:textStyle="bold"
                            android:textColor="?android:attr/textColorPrimary" />
                        <TextView
                            android:id="@+id/stream_name"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Musichitz Looktung"
                            android:textColor="?android:attr/textColorPrimary" />
                    </LinearLayout>

                    <!-- Stream Description -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingVertical="4dp">
                        <TextView
                            android:layout_width="140dp"
                            android:layout_height="wrap_content"
                            android:text="Description:"
                            android:textStyle="bold"
                            android:textColor="?android:attr/textColorPrimary" />
                        <TextView
                            android:id="@+id/stream_description"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="ฮิตทั่วฟ้า แฟนเพลงขวัญใจมหาชน"
                            android:textColor="?android:attr/textColorPrimary" />
                    </LinearLayout>

                    <!-- Content Type -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingVertical="4dp">
                        <TextView
                            android:layout_width="140dp"
                            android:layout_height="wrap_content"
                            android:text="Content Type:"
                            android:textStyle="bold"
                            android:textColor="?android:attr/textColorPrimary" />
                        <TextView
                            android:id="@+id/stream_content_type"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="audio/mpeg"
                            android:textColor="?android:attr/textColorPrimary" />
                    </LinearLayout>

                    <!-- Stream Started -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingVertical="4dp">
                        <TextView
                            android:layout_width="140dp"
                            android:layout_height="wrap_content"
                            android:text="Stream Started:"
                            android:textStyle="bold"
                            android:textColor="?android:attr/textColorPrimary" />
                        <TextView
                            android:id="@+id/stream_started"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Fri, 17 Jul 2026 14:38:26 +0700"
                            android:textColor="?android:attr/textColorPrimary" />
                    </LinearLayout>

                    <!-- Bitrate -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingVertical="4dp">
                        <TextView
                            android:layout_width="140dp"
                            android:layout_height="wrap_content"
                            android:text="Bitrate:"
                            android:textStyle="bold"
                            android:textColor="?android:attr/textColorPrimary" />
                        <TextView
                            android:id="@+id/stream_bitrate"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="128 kbps"
                            android:textColor="?android:attr/textColorPrimary" />
                    </LinearLayout>

                    <!-- Listeners -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingVertical="4dp">
                        <TextView
                            android:layout_width="140dp"
                            android:layout_height="wrap_content"
                            android:text="Listeners:"
                            android:textStyle="bold"
                            android:textColor="?android:attr/textColorPrimary" />
                        <TextView
                            android:id="@+id/stream_listeners"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="1 (Peak: 4)"
                            android:textColor="?android:attr/textColorPrimary" />
                    </LinearLayout>

                    <!-- Genre -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingVertical="4dp">
                        <TextView
                            android:layout_width="140dp"
                            android:layout_height="wrap_content"
                            android:text="Genre:"
                            android:textStyle="bold"
                            android:textColor="?android:attr/textColorPrimary" />
                        <TextView
                            android:id="@+id/stream_genre"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Country"
                            android:textColor="?android:attr/textColorPrimary" />
                    </LinearLayout>

                    <!-- Stream Web URL -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingVertical="4dp">
                        <TextView
                            android:layout_width="140dp"
                            android:layout_height="wrap_content"
                            android:text="Stream URL:"
                            android:textStyle="bold"
                            android:textColor="?android:attr/textColorPrimary" />
                        <TextView
                            android:id="@+id/stream_url"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="https://musichitz.net/looktung.html"
                            android:textColor="?attr/colorAccent" />
                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Refresh Button -->
            <Button
                android:id="@+id/refresh_info_button"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:text="Refresh Info"
                android:textColor="?attr/colorAccent" />

        </LinearLayout>

    </ScrollView>

</io.mrarm.irc.view.OpaqueStatusBarRelativeLayout>
